# Flow-Factory machine/runtime configuration.
#
# Copy this file to .env. The launcher treats values already present in the
# calling environment as explicit overrides, so this remains valid:
#   CONFIG=examples/nft/lora/sd3_5/geneval_stock.yaml ./scripts/train_nft_geneval_baseline.sh

# Node-local runtime. Training, caches, W&B files, and checkpoints stay off the
# slow Sensei filesystem.
SOURCE_REPO=/sensei-fs-3/users/yunfeix/origin_flowfactory/Flow-Factory
RUNTIME_ROOT=/mnt/localssd/flowfactory
CUDA_ROOT=/sensei-fs-3/users/yunfeix/miniforge3/envs/flow-factory
REPO_ROOT=${RUNTIME_ROOT}/code/Flow-Factory
CONDA_ENV=${RUNTIME_ROOT}/env
PYTHON_OVERLAY=${RUNTIME_ROOT}/python-overlay
LOCAL_HOME=${RUNTIME_ROOT}/home
LOCAL_CACHE=${RUNTIME_ROOT}/cache
LOCAL_TMP=${RUNTIME_ROOT}/tmp
FLOWFACTORY_HF_HOME=${RUNTIME_ROOT}/cache/huggingface
CUDA_LIBRARY_PATH=${CONDA_ENV}/lib
NETRC_SOURCE=/home/colligo/.netrc

# Default experiment. Distributed launch settings remain in the YAML and are
# consumed by flow_factory.cli; the shell launcher does not duplicate them.
CONFIG=examples/nft/lora/sd3_5/geneval.yaml
WANDB_MODE=offline
WANDB_ENTITY=vlaa-med
HF_HUB_OFFLINE=1

# Checkpoint policy. Set a run-specific S3 prefix before relying on local-SSD
# checkpoints for recovery. Credentials come from the host IAM/AWS setup, not
# this file.
CHECKPOINT_S3_URI=
CHECKPOINT_RETENTION=2
CHECKPOINT_UPLOAD_TOOL=s5cmd
CHECKPOINT_UPLOAD_CONCURRENCY=32

# Cold-node preparation inputs. Miniforge is installed directly on local SSD,
# then its local Conda creates the CPython 3.12 environment required by MMCV.
MINIFORGE_URL=https://github.com/conda-forge/miniforge/releases/download/26.3.2-3/Miniforge3-Linux-x86_64.sh
MINIFORGE_SHA256=848194851a98903134187fbb4ab50efe87b003e0c0f808f97644b7524a62bf2c
RUNTIME_PYTHON_VERSION=3.12
SOURCE_HF=/sensei-fs-3/users/yunfeix/hf_cache
MODEL_CACHE=hub/models--stabilityai--stable-diffusion-3.5-medium
CLIP_CACHE=hub/models--timm--vit_large_patch14_clip_224.openai
PICKSCORE_PROCESSOR_CACHE=hub/models--laion--CLIP-ViT-H-14-laion2B-s32B-b79K
PICKSCORE_MODEL_CACHE=hub/models--yuvalkirstain--PickScore_v1
CLIPSCORE_CACHE=hub/models--openai--clip-vit-large-patch14
PICKSCORE_PROCESSOR_REPO=laion/CLIP-ViT-H-14-laion2B-s32B-b79K
PICKSCORE_PROCESSOR_REVISION=1c2b8495b28150b8a4922ee1c8edee224c284c0c
PICKSCORE_MODEL_REPO=yuvalkirstain/PickScore_v1
PICKSCORE_MODEL_REVISION=a4e4367c6dfa7288a00c550414478f865b875800
CLIPSCORE_REPO=openai/clip-vit-large-patch14
CLIPSCORE_REVISION=32bd64288804d66eefd0ccbe215aa642df71cc41
DATASET_SOURCE=/sensei-fs-3/users/yunfeix/flow_rl_adobe/diffusion-rl-gemini-async/DiffusionNFT/dataset/geneval_knowledge_intrinsic_v0
DATASET_NAME=geneval_knowledge_intrinsic_v0/v1
NO_REWRITE_DATASET_NAME=geneval_knowledge_intrinsic_v0/no_rewrite
PICKAPIC_DATASET_SOURCE=/sensei-fs-3/users/yunfeix/flow_rl_adobe/diffusion-rl-gemini-async/DiffusionNFT/dataset/pickscore
PICKAPIC_DATASET_NAME=pickapic_advantageflow
PICKAPIC_REWRITE_DATASET_SOURCE=/sensei-fs-3/users/yunfeix/flow_rl_adobe/diffusion-rl-gemini-async/DiffusionNFT/dataset/pickscore_balanced_v0_pairs
PICKAPIC_REWRITE_DATASET_NAME=pickapic_balanced_v0_pairs
HPSV2_CHECKPOINT_URL=https://huggingface.co/xswu/HPSv2/resolve/main/HPS_v2.1_compressed.pt
HPSV2_CHECKPOINT_SHA256=c57a38fb4a2f7e7c15bf00da2ea377cdf165448b4dd1052a484c215a998c9837
HPSV2_CHECKPOINT=${RUNTIME_ROOT}/cache/torch/hub/checkpoints/HPS_v2.1_compressed.pt
HPSV2_BPE_URL=https://openaipublic.azureedge.net/clip/bpe_simple_vocab_16e6.txt.gz
HPSV2_BPE_SHA256=924691ac288e54409236115652ad4aa250f48203de50a9e4722a6ecd48d6804a
MMCV_WHEEL=${SOURCE_REPO}/.scratch/artifacts/mmcv/sm80-sm90/mmcv-2.1.0-cp312-cp312-linux_x86_64.whl
MAX_JOBS=4
TORCH_CUDA_ARCH_LIST="8.0;9.0"
MMCV_WITH_OPS=1
FORCE_CUDA=1
GENEVAL_BUILD_DIR=${RUNTIME_ROOT}/build/geneval
GENEVAL_MMCV_VERSION=2.1.0
GENEVAL_DETECTOR_URL=https://download.openmmlab.com/mmdetection/v3.0/mask2former/mask2former_swin-s-p4-w7-224_8xb2-lsj-50e_coco/mask2former_swin-s-p4-w7-224_8xb2-lsj-50e_coco_20220504_001756-c9d0c4f2.pth
GENEVAL_DETECTOR_SHA256=c9d0c4f21c47ecdfaf7595ff1edfa42158d70cbd8c79e93e1c76d5fcad58cd47

# Optional reward-server launchers.
VLLM_BIN=vllm
VLLM_HOST=0.0.0.0
VLLM_PORT=8000
VLLM_GPU_MEMORY_UTILIZATION=0.9
QWEN_IMAGE_BENCH_MODEL_PATH=Qwen/Qwen-Image-Bench
QWEN_IMAGE_BENCH_SERVED_MODEL_NAME=Qwen-Image-Bench
QWEN_IMAGE_BENCH_TENSOR_PARALLEL_SIZE=
RATIONAL_REWARD_MODEL_PATH=TIGER-Lab/RationalRewards-8B-T2I
RATIONAL_REWARD_SERVED_MODEL_NAME=
RATIONAL_REWARD_TENSOR_PARALLEL_SIZE=1
RATIONAL_REWARD_DATA_PARALLEL_SIZE=
